// SideSale — Open source POS
// Run `prisma migrate dev --name init` after changes.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  CASHIER
}

enum PaymentMethod {
  CASH
  PROMPTPAY
}

enum SaleStatus {
  COMPLETED
  VOID
}

enum StockMovementType {
  IN
  OUT
  ADJUST
  VOID_RETURN
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(CASHIER)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales           Sale[]
  stockMovements  StockMovement[]
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6366f1")
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@index([sortOrder])
}

model Product {
  id                   String    @id @default(cuid())
  sku                  String    @unique
  barcode              String?   @unique
  name                 String
  description          String?
  categoryId           String?
  category             Category? @relation(fields: [categoryId], references: [id])
  unit                 String    @default("piece")  // piece, kg, g, bottle, pack, bag, box, etc.
  price                Decimal   @db.Decimal(12, 2)
  cost                 Decimal   @db.Decimal(12, 2) @default(0)
  stock                Int       @default(0)
  lowStockThreshold    Int       @default(5)
  imageUrl             String?
  active               Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  saleItems       SaleItem[]
  stockMovements  StockMovement[]

  @@index([name])
  @@index([active])
  @@index([categoryId])
}

model Customer {
  id        String   @id @default(cuid())
  code      String   @unique              // e.g. M-0001
  name      String
  phone     String?  @unique
  email     String?
  points    Int      @default(0)
  totalSpent Decimal @db.Decimal(12, 2) @default(0)
  visitCount Int     @default(0)
  note      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales        Sale[]
  pointHistory PointHistory[]

  @@index([name])
  @@index([phone])
}

model PointHistory {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  saleId     String?
  change     Int                // positive = earn, negative = redeem
  balance    Int                // points balance after this change
  reason     String             // "earn", "redeem", "adjust", "void_reverse"
  createdAt  DateTime @default(now())

  @@index([customerId])
  @@index([createdAt])
}

model Sale {
  id            String        @id @default(cuid())
  number        String        @unique
  cashierId     String
  cashier       User          @relation(fields: [cashierId], references: [id])
  customerId    String?
  customer      Customer?     @relation(fields: [customerId], references: [id])
  subtotal      Decimal       @db.Decimal(12, 2)
  discount      Decimal       @db.Decimal(12, 2) @default(0)
  total         Decimal       @db.Decimal(12, 2)
  pointsEarned  Int           @default(0)
  pointsRedeemed Int          @default(0)
  paymentMethod PaymentMethod
  paidAmount    Decimal       @db.Decimal(12, 2)
  change        Decimal       @db.Decimal(12, 2) @default(0)
  status        SaleStatus    @default(COMPLETED)
  note          String?
  voidReason    String?
  voidAt        DateTime?
  voidById      String?
  createdAt     DateTime      @default(now())

  items SaleItem[]

  @@index([createdAt])
  @@index([cashierId])
  @@index([customerId])
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  name      String  // snapshot
  unit      String  @default("piece")  // snapshot
  unitPrice Decimal @db.Decimal(12, 2)
  quantity  Int
  subtotal  Decimal @db.Decimal(12, 2)

  @@index([saleId])
  @@index([productId])
}

model StockMovement {
  id         String            @id @default(cuid())
  productId  String
  product    Product           @relation(fields: [productId], references: [id])
  type       StockMovementType
  quantity   Int
  reason     String?
  userId     String?
  user       User?             @relation(fields: [userId], references: [id])
  createdAt  DateTime          @default(now())

  @@index([productId])
  @@index([createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  entity     String   // "product", "category", "sale", "settings", "user"
  entityId   String
  action     String   // "create", "update", "delete", "void"
  changes    String?  // JSON diff of changed fields
  userId     String
  userName   String
  createdAt  DateTime @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
  @@index([userId])
}

model Settings {
  id               Int      @id @default(1)
  shopName         String   @default("SideSale Demo Shop")
  promptpayId      String   @default("")
  currency         String   @default("THB")
  taxRate          Decimal  @db.Decimal(5, 2) @default(0)
  pointsPerBaht    Int      @default(1)      // earn X points per 1 baht spent
  pointValue       Decimal  @db.Decimal(8, 2) @default(0.25) // 1 point = X baht discount
  minPointsRedeem  Int      @default(100)    // minimum points to redeem
  updatedAt        DateTime @updatedAt
}
