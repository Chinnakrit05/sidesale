# ⚠️  Copy this file to .env and change ALL values before deploying!
# cp .env.example .env

# ---------- Database ----------
POSTGRES_USER=sidesale
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
POSTGRES_DB=sidesale
DATABASE_URL=postgresql://sidesale:CHANGE_ME_USE_STRONG_PASSWORD@db:5432/sidesale?schema=public

# ---------- NextAuth ----------
# Generate a secret: openssl rand -base64 32
AUTH_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32
AUTH_TRUST_HOST=true
NEXTAUTH_URL=http://localhost:3000

# ---------- Seed / default accounts ----------
# Created on first run if no users exist.
SEED_OWNER_EMAIL=owner@yourshop.com
SEED_OWNER_PASSWORD=CHANGE_ME_MIN_8_CHARS
SEED_CASHIER_EMAIL=cashier@yourshop.com
SEED_CASHIER_PASSWORD=CHANGE_ME_MIN_8_CHARS

# ---------- Shop settings ----------
SHOP_NAME=My Shop
# PromptPay ID: Thai mobile (0891234567) or national ID (1234567890123)
PROMPTPAY_ID=
CURRENCY=THB
